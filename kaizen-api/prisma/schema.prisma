generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Department {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String                @unique @db.VarChar(120)
  code                 String                @unique @db.VarChar(20)
  managerId            String?               @map("manager_id") @db.Uuid
  isActive             Boolean               @default(true) @map("is_active")
  createdAt            DateTime              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime              @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?             @map("deleted_at") @db.Timestamptz(6)
  manager              User?                 @relation("DepartmentManager", fields: [managerId], references: [id])
  implementations      Implementation[]
  kaizens              Kaizen[]
  knowledgeBaseEntries KnowledgeBaseEntry[]
  leaderboardSnapshots LeaderboardSnapshot[]
  employees            User[]                @relation("DepartmentEmployees")

  @@index([managerId])
  @@index([isActive])
  @@map("departments")
}

model Category {
  id                   String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String               @unique @db.VarChar(80)
  slug                 String               @unique @db.VarChar(80)
  description          String?              @db.VarChar(255)
  icon                 String?              @db.VarChar(50)
  sortOrder            Int                  @default(0) @map("sort_order")
  isActive             Boolean              @default(true) @map("is_active")
  createdAt            DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt            DateTime?            @map("deleted_at") @db.Timestamptz(6)
  kaizens              Kaizen[]
  knowledgeBaseEntries KnowledgeBaseEntry[]

  @@map("categories")
}

/// Synced from Clerk via webhook; application data stored here.
model User {
  id                                String                     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// Permanent, unique, assigned once at creation (see authService.syncUser) — never reassigned or
  /// edited afterward. Embedded in every Kaizen number submitted by this employee going forward
  /// (see nextKaizenNumber in kaizen.service.ts).
  employeeCode                      String                     @unique @map("employee_code") @db.VarChar(20)
  clerkId                           String                     @unique @map("clerk_id") @db.VarChar(255)
  email                             String                     @unique @db.VarChar(255)
  firstName                         String                     @map("first_name") @db.VarChar(100)
  lastName                          String                     @map("last_name") @db.VarChar(100)
  displayName                       String                     @map("display_name") @db.VarChar(200)
  avatarUrl                         String?                    @map("avatar_url")
  departmentId                      String?                    @map("department_id") @db.Uuid
  role                              UserRole                   @default(EMPLOYEE)
  jobTitle                          String?                    @map("job_title") @db.VarChar(120)
  phone                             String?                    @db.VarChar(20)
  isActive                          Boolean                    @default(true) @map("is_active")
  lastLoginAt                       DateTime?                  @map("last_login_at") @db.Timestamptz(6)
  createdAt                         DateTime                   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                         DateTime                   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt                         DateTime?                  @map("deleted_at") @db.Timestamptz(6)
  announcements                     Announcement[]
  auditLogs                         AuditLog[]
  recordedBusinessImpacts           BusinessImpact[]
  managedDepartments                Department[]               @relation("DepartmentManager")
  evaluations                       Evaluation[]
  uploadedImplementationAttachments ImplementationAttachment[]
  ownedImplementations              Implementation[]           @relation("ImplementationOwner")
  verifiedImplementations           Implementation[]           @relation("ImplementationVerifier")
  uploadedKaizenAttachments         KaizenAttachment[]
  owningKaizens                     Kaizen[]                   @relation("KaizenOwner")
  reviewingKaizens                  Kaizen[]                   @relation("KaizenReviewer")
  submittedKaizens                  Kaizen[]                   @relation("KaizenSubmitter")
  publishedKnowledgeBaseEntries     KnowledgeBaseEntry[]
  notifications                     Notification[]
  updatedPlatformSettings           PlatformSetting[]
  issuedPointsLedgerEntries         PointsLedger[]             @relation("PointsLedgerIssuer")
  pointsLedgerEntries               PointsLedger[]             @relation("PointsLedgerUser")
  reportExports                     ReportExport[]
  reportGenerations                 ReportGeneration[]
  reportSchedules                   ReportSchedule[]
  reportTemplates                   ReportTemplate[]
  reviewComments                    ReviewComment[]
  rewardsIssued                     Reward[]                   @relation("RewardIssuer")
  rewardsReceived                   Reward[]                   @relation("RewardRecipient")
  savedViews                        SavedView[]
  timelineEvents                    TimelineEvent[]
  userAchievements                  UserAchievement[]
  gamification                      UserGamification?
  department                        Department?                @relation("DepartmentEmployees", fields: [departmentId], references: [id])

  @@index([departmentId])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

/// Denormalized gamification summary for fast dashboard reads.
model UserGamification {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @unique @map("user_id") @db.Uuid
  totalPoints      Int      @default(0) @map("total_points")
  ideasSubmitted   Int      @default(0) @map("ideas_submitted")
  ideasApproved    Int      @default(0) @map("ideas_approved")
  ideasImplemented Int      @default(0) @map("ideas_implemented")
  currentRank      Int?     @map("current_rank")
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  user             User     @relation(fields: [userId], references: [id])

  @@map("user_gamification")
}

model KaizenNumberSequence {
  year      Int @id
  lastValue Int @default(0) @map("last_value")

  @@map("kaizen_number_sequences")
}

/// Single-row global counter (`id` fixed at 1) for `User.employeeCode` — same upsert-and-increment
/// pattern as KaizenNumberSequence above, just not year-scoped since employee codes never repeat.
model EmployeeCodeSequence {
  id        Int @id @default(1)
  lastValue Int @default(0) @map("last_value")

  @@map("employee_code_sequence")
}

model Kaizen {
  id                    String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  /// "KZN-{year}-{seq}" for Kaizens submitted before the employee-code format existed;
  /// "KZN-{submitter employeeCode}-{year}-{seq}" going forward — see `nextKaizenNumber` in
  /// kaizen.service.ts. Widened from VARCHAR(20) to fit the longer format.
  kaizenNumber          String              @unique @map("kaizen_number") @db.VarChar(40)
  title                 String              @db.VarChar(120)
  status                KaizenStatus        @default(DRAFT)
  priority              KaizenPriority      @default(MEDIUM)
  estimatedImpact       EstimatedImpact     @default(MEDIUM) @map("estimated_impact")
  location              String?             @db.VarChar(120)
  problemStatement      String?             @map("problem_statement")
  currentProcess        String?             @map("current_process")
  proposedSolution      String?             @map("proposed_solution")
  categoryId            String?             @map("category_id") @db.Uuid
  departmentId          String              @map("department_id") @db.Uuid
  submitterId           String              @map("submitter_id") @db.Uuid
  assignedReviewerId    String?             @map("assigned_reviewer_id") @db.Uuid
  assignedOwnerId       String?             @map("assigned_owner_id") @db.Uuid
  implementationDueDate DateTime?           @map("implementation_due_date") @db.Date
  submittedAt           DateTime?           @map("submitted_at") @db.Timestamptz(6)
  approvedAt            DateTime?           @map("approved_at") @db.Timestamptz(6)
  archivedAt            DateTime?           @map("archived_at") @db.Timestamptz(6)
  createdAt             DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  businessImpact        BusinessImpact?
  evaluations           Evaluation[]
  implementation        Implementation?
  fiveW1H               Kaizen5W1H?
  costOfImplementation  KaizenCostOfImplementation?
  attachments           KaizenAttachment[]
  benefits              KaizenBenefit[]
  assignedOwner         User?               @relation("KaizenOwner", fields: [assignedOwnerId], references: [id])
  assignedReviewer      User?               @relation("KaizenReviewer", fields: [assignedReviewerId], references: [id])
  category              Category?           @relation(fields: [categoryId], references: [id])
  department            Department          @relation(fields: [departmentId], references: [id])
  submitter             User                @relation("KaizenSubmitter", fields: [submitterId], references: [id])
  knowledgeBaseEntry    KnowledgeBaseEntry?
  pointsLedgerEntries   PointsLedger[]
  reviewComments        ReviewComment[]
  rewards               Reward[]
  timelineEvents        TimelineEvent[]

  @@index([status])
  @@index([departmentId])
  @@index([submitterId])
  @@index([categoryId])
  @@index([assignedReviewerId])
  @@index([submittedAt])
  @@index([status, departmentId])
  @@index([submitterId, status])
  @@map("kaizens")
}

/// One row per Kaizen.
model Kaizen5W1H {
  id            String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId      String  @unique @map("kaizen_id") @db.Uuid
  what          String?
  whereLocation String? @map("where_location")
  whenOccurs    String? @map("when_occurs")
  who           String?
  why           String?
  how           String?
  kaizen        Kaizen  @relation(fields: [kaizenId], references: [id], onDelete: Cascade)

  @@map("kaizen_5w1h")
}

/// One row per Kaizen — replaces the removed Kaizen5Why step. Every field is nullable at the DB
/// layer, same as Kaizen5W1H above: this is upserted incrementally by wizard autosave, so
/// "required" is enforced only at submit-time validation (kaizen.service.ts#validateForSubmit),
/// never at the schema layer.
model KaizenCostOfImplementation {
  id                               String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId                         String        @unique @map("kaizen_id") @db.Uuid
  costType                         CostType?     @map("cost_type")
  estimatedCost                    Decimal?      @map("estimated_cost") @db.Decimal(12, 2)
  currency                         String        @default("INR") @db.VarChar(10)
  estimatedDurationValue           Int?          @map("estimated_duration_value")
  estimatedDurationUnit            DurationUnit? @map("estimated_duration_unit")
  employeesRequired                Int?          @map("employees_required")
  /// Department IDs, not a relation table — this is a lightweight multi-select on an estimation
  /// form, not a referential-integrity-critical link (departments are soft-deleted, never hard
  /// deleted, so a stale id here just stops resolving to a name rather than breaking anything).
  departmentIds                    String[]      @map("department_ids")
  materialsRequired                String?       @map("materials_required")
  machinesRequired                 String?       @map("machines_required")
  vendorRequired                   Boolean       @default(false) @map("vendor_required")
  vendorDetails                    String?       @map("vendor_details") @db.VarChar(1000)
  estimatedAnnualSavings           Decimal?      @map("estimated_annual_savings") @db.Decimal(12, 2)
  timeSavedHoursPerDay             Decimal?      @map("time_saved_hours_per_day") @db.Decimal(6, 2)
  qualityImprovement               ImpactLevel?  @map("quality_improvement")
  safetyImprovement                ImpactLevel?  @map("safety_improvement")
  customerSatisfactionImprovement  ImpactLevel?  @map("customer_satisfaction_improvement")
  wasteReductionImprovement        ImpactLevel?  @map("waste_reduction_improvement")
  expectedPaybackPeriod            String?       @map("expected_payback_period") @db.VarChar(100)
  additionalNotes                  String?       @map("additional_notes") @db.VarChar(1000)
  createdAt                        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  kaizen                           Kaizen        @relation(fields: [kaizenId], references: [id], onDelete: Cascade)

  @@map("kaizen_cost_of_implementation")
}

model KaizenBenefit {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId    String  @map("kaizen_id") @db.Uuid
  benefitType String  @map("benefit_type") @db.VarChar(50)
  description String  @db.VarChar(500)
  isCustom    Boolean @default(false) @map("is_custom")
  sortOrder   Int     @default(0) @map("sort_order")
  kaizen      Kaizen  @relation(fields: [kaizenId], references: [id], onDelete: Cascade)

  @@map("kaizen_benefits")
}

/// Max 10 attachments per Kaizen — enforced at the application layer.
model KaizenAttachment {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId            String         @map("kaizen_id") @db.Uuid
  fileName            String         @map("file_name") @db.VarChar(255)
  fileType            AttachmentType @map("file_type")
  mimeType            String         @map("mime_type") @db.VarChar(100)
  fileSizeBytes       BigInt         @map("file_size_bytes")
  cloudinaryPublicId  String         @map("cloudinary_public_id") @db.VarChar(255)
  cloudinaryUrl       String         @map("cloudinary_url")
  cloudinarySecureUrl String         @map("cloudinary_secure_url")
  tag                 AttachmentTag  @default(GENERAL)
  caption             String?        @db.VarChar(255)
  sortOrder           Int            @default(0) @map("sort_order")
  uploadedById        String         @map("uploaded_by_id") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  kaizen              Kaizen         @relation(fields: [kaizenId], references: [id], onDelete: Cascade)
  uploadedBy          User           @relation(fields: [uploadedById], references: [id])

  @@map("kaizen_attachments")
}

/// Configurable by Super Admin. MVP ships with 5 default parameters.
model ScoringParameter {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @db.VarChar(100)
  slug             String            @unique @db.VarChar(100)
  description      String
  guidelines       String
  maxScore         Int               @default(10) @map("max_score")
  sortOrder        Int               @default(0) @map("sort_order")
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  evaluationScores EvaluationScore[]

  @@map("scoring_parameters")
}

/// One final evaluation per reviewer per Kaizen (MVP: one department manager).
model Evaluation {
  id             String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId       String               @map("kaizen_id") @db.Uuid
  reviewerId     String               @map("reviewer_id") @db.Uuid
  recommendation ReviewRecommendation
  confidence     ReviewConfidence?
  remarks        String?
  totalScore     Int                  @map("total_score")
  overallRating  Decimal              @map("overall_rating") @db.Decimal(3, 1)
  isSubmitted    Boolean              @default(false) @map("is_submitted")
  submittedAt    DateTime?            @map("submitted_at") @db.Timestamptz(6)
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  scores         EvaluationScore[]
  kaizen         Kaizen               @relation(fields: [kaizenId], references: [id])
  reviewer       User                 @relation(fields: [reviewerId], references: [id])

  @@unique([kaizenId, reviewerId])
  @@map("evaluations")
}

/// NOTE: `score` should additionally be constrained CHECK (score BETWEEN 0 AND 10) —
/// add via a follow-up raw-SQL migration.
model EvaluationScore {
  id           String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  evaluationId String           @map("evaluation_id") @db.Uuid
  parameterId  String           @map("parameter_id") @db.Uuid
  score        Int
  evaluation   Evaluation       @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  parameter    ScoringParameter @relation(fields: [parameterId], references: [id])

  @@unique([evaluationId, parameterId])
  @@map("evaluation_scores")
}

/// Comments cannot be edited after Kaizen approval (application rule).
model ReviewComment {
  id         String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId   String          @map("kaizen_id") @db.Uuid
  authorId   String          @map("author_id") @db.Uuid
  parentId   String?         @map("parent_id") @db.Uuid
  body       String
  isResolved Boolean         @default(false) @map("is_resolved")
  createdAt  DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  author     User            @relation(fields: [authorId], references: [id])
  kaizen     Kaizen          @relation(fields: [kaizenId], references: [id], onDelete: Cascade)
  parent     ReviewComment?  @relation("ReviewCommentReplies", fields: [parentId], references: [id])
  replies    ReviewComment[] @relation("ReviewCommentReplies")

  @@map("review_comments")
}

/// One row per Kaizen after approval.
/// NOTE: `progress_percent` should additionally be constrained CHECK (progress_percent BETWEEN 0 AND 100) —
/// add via a follow-up raw-SQL migration.
model Implementation {
  id                   String                           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId             String                           @unique @map("kaizen_id") @db.Uuid
  ownerId              String                           @map("owner_id") @db.Uuid
  assignedDepartmentId String                           @map("assigned_department_id") @db.Uuid
  description          String?
  progressPercent      Int                              @default(0) @map("progress_percent")
  estimatedCost        Decimal?                         @map("estimated_cost") @db.Decimal(12, 2)
  actualCost           Decimal?                         @map("actual_cost") @db.Decimal(12, 2)
  timeTakenDays        Int?                             @map("time_taken_days")
  startedAt            DateTime?                        @map("started_at") @db.Timestamptz(6)
  completedAt          DateTime?                        @map("completed_at") @db.Timestamptz(6)
  completionNotes      String?                          @map("completion_notes")
  verificationStatus   ImplementationVerificationStatus @default(PENDING) @map("verification_status")
  verifiedById         String?                          @map("verified_by_id") @db.Uuid
  verifiedAt           DateTime?                        @map("verified_at") @db.Timestamptz(6)
  createdAt            DateTime                         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime                         @updatedAt @map("updated_at") @db.Timestamptz(6)
  attachments          ImplementationAttachment[]
  assignedDepartment   Department                       @relation(fields: [assignedDepartmentId], references: [id])
  kaizen               Kaizen                           @relation(fields: [kaizenId], references: [id])
  owner                User                             @relation("ImplementationOwner", fields: [ownerId], references: [id])
  verifiedBy           User?                            @relation("ImplementationVerifier", fields: [verifiedById], references: [id])

  @@map("implementations")
}

model ImplementationAttachment {
  id                  String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  implementationId    String         @map("implementation_id") @db.Uuid
  fileName            String         @map("file_name") @db.VarChar(255)
  fileType            AttachmentType @map("file_type")
  mimeType            String         @map("mime_type") @db.VarChar(100)
  fileSizeBytes       BigInt         @map("file_size_bytes")
  cloudinaryPublicId  String         @map("cloudinary_public_id") @db.VarChar(255)
  cloudinarySecureUrl String         @map("cloudinary_secure_url")
  uploadedById        String         @map("uploaded_by_id") @db.Uuid
  createdAt           DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  implementation      Implementation @relation(fields: [implementationId], references: [id], onDelete: Cascade)
  uploadedBy          User           @relation(fields: [uploadedById], references: [id])

  @@map("implementation_attachments")
}

model BusinessImpact {
  id                              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId                        String   @unique @map("kaizen_id") @db.Uuid
  moneySaved                      Decimal? @map("money_saved") @db.Decimal(14, 2)
  hoursSaved                      Decimal? @map("hours_saved") @db.Decimal(10, 2)
  employeesBenefited              Int?     @map("employees_benefited")
  customersBenefited              Int?     @map("customers_benefited")
  processImprovement              Boolean  @default(false) @map("process_improvement")
  qualityImprovement              Boolean  @default(false) @map("quality_improvement")
  safetyImprovement               Boolean  @default(false) @map("safety_improvement")
  productivityImprovement         Boolean  @default(false) @map("productivity_improvement")
  customerSatisfactionImprovement Boolean  @default(false) @map("customer_satisfaction_improvement")
  remarks                         String?
  recordedById                    String   @map("recorded_by_id") @db.Uuid
  createdAt                       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  kaizen                          Kaizen   @relation(fields: [kaizenId], references: [id])
  recordedBy                      User     @relation(fields: [recordedById], references: [id])

  @@map("business_impacts")
}

/// Append-only points history.
model PointsLedger {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  amount     Int
  reason     String   @db.VarChar(100)
  kaizenId   String?  @map("kaizen_id") @db.Uuid
  issuedById String?  @map("issued_by_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  issuedBy   User?    @relation("PointsLedgerIssuer", fields: [issuedById], references: [id])
  kaizen     Kaizen?  @relation(fields: [kaizenId], references: [id])
  user       User     @relation("PointsLedgerUser", fields: [userId], references: [id])

  @@map("points_ledger")
}

model Achievement {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code             String            @unique @db.VarChar(50)
  name             String            @db.VarChar(100)
  description      String            @db.VarChar(255)
  icon             String            @db.VarChar(50)
  rarity           AchievementRarity @default(COMMON)
  pointsAwarded    Int               @default(25) @map("points_awarded")
  criteria         Json
  isActive         Boolean           @default(true) @map("is_active")
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String      @map("user_id") @db.Uuid
  achievementId String      @map("achievement_id") @db.Uuid
  earnedAt      DateTime    @default(now()) @map("earned_at") @db.Timestamptz(6)
  achievement   Achievement @relation(fields: [achievementId], references: [id])
  user          User        @relation(fields: [userId], references: [id])

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Reward {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  kaizenId   String   @map("kaizen_id") @db.Uuid
  points     Int
  reason     String   @db.VarChar(255)
  issuedById String?  @map("issued_by_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  issuedBy   User?    @relation("RewardIssuer", fields: [issuedById], references: [id])
  kaizen     Kaizen   @relation(fields: [kaizenId], references: [id])
  user       User     @relation("RewardRecipient", fields: [userId], references: [id])

  @@map("rewards")
}

/// Precomputed rankings refreshed on reward events and every 5 minutes (cron).
model LeaderboardSnapshot {
  id           String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  period       LeaderboardPeriod
  scope        LeaderboardScope
  departmentId String?           @map("department_id") @db.Uuid
  rankings     Json
  computedAt   DateTime          @map("computed_at") @db.Timestamptz(6)
  department   Department?       @relation(fields: [departmentId], references: [id])

  @@unique([period, scope, departmentId])
  @@map("leaderboard_snapshots")
}

model KnowledgeBaseEntry {
  id            String                   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kaizenId      String                   @unique @map("kaizen_id") @db.Uuid
  title         String                   @db.VarChar(200)
  summary       String
  problem       String
  solution      String
  benefits      String
  departmentId  String                   @map("department_id") @db.Uuid
  categoryId    String                   @map("category_id") @db.Uuid
  tags          String[]                 @default([])
  publishedById String                   @map("published_by_id") @db.Uuid
  publishedAt   DateTime                 @map("published_at") @db.Timestamptz(6)
  /// Generated full-text search column; added + indexed (GIN) via raw-SQL migration 002.
  searchVector  Unsupported("tsvector")?
  category      Category                 @relation(fields: [categoryId], references: [id])
  department    Department               @relation(fields: [departmentId], references: [id])
  kaizen        Kaizen                   @relation(fields: [kaizenId], references: [id])
  publishedBy   User                     @relation(fields: [publishedById], references: [id])

  @@index([tags], type: Gin)
  @@map("knowledge_base_entries")
}

model Notification {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String           @map("user_id") @db.Uuid
  type       NotificationType
  title      String           @db.VarChar(200)
  body       String
  entityType String?          @map("entity_type") @db.VarChar(50)
  entityId   String?          @map("entity_id") @db.Uuid
  isRead     Boolean          @default(false) @map("is_read")
  readAt     DateTime?        @map("read_at") @db.Timestamptz(6)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User             @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

model Announcement {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String     @db.VarChar(200)
  body        String
  authorId    String     @map("author_id") @db.Uuid
  targetRoles UserRole[] @map("target_roles")
