/// Which list page a SavedView's `filters` JSON applies to — matches the shape each list
/// endpoint's own query schema already accepts.
enum SavedViewEntityType {
  KAIZEN_LIST
  REVIEW_QUEUE
  IMPLEMENTATION_QUEUE
  ADMIN_USERS
  REPORTS
}

/// A user's saved filter/sort combination for a list page (Milestone 11 Chunk 2). `filters` is
/// the exact query-string-shaped JSON object the corresponding list endpoint already accepts
/// (e.g. `{"status":"UNDER_REVIEW","priority":"HIGH"}`) — no new filter vocabulary, just a name
/// for a previously-typed-out combination. `isShared` only has meaning when set by a Super Admin
/// (enforced at the service layer, not the schema) — everyone else's saved views are private.
model SavedView {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  entityType   SavedViewEntityType @map("entity_type")
  name         String              @db.VarChar(100)
  filters      Json
  isDefault    Boolean             @default(false) @map("is_default")
  isShared     Boolean             @default(false) @map("is_shared")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User                @relation(fields: [userId], references: [id])

  @@index([userId, entityType])
  @@map("saved_views")
}

/// The 10 report types Milestone 11 Chunk 3A supports — matches the Report Builder's own
/// "Report Type" selector exactly.
enum ReportType {
  EXECUTIVE_SUMMARY
  MONTHLY
  DEPARTMENT
  EMPLOYEE_PERFORMANCE
  KAIZEN_PERFORMANCE
  REVIEW_PERFORMANCE
  IMPLEMENTATION
  BUSINESS_IMPACT
  REWARD
  LEADERBOARD
}

/// Report generation history (Milestone 11 Chunk 3A Part 10) — "history only, no downloads yet"
/// per the brief; the actual report output is never persisted, only the fact that it was
/// generated, by whom, with which filters, and how long it took. `durationMs` is measured around
/// the same aggregation call the live preview uses, not a separate file-generation step (there is
/// no file yet — see Chunk 3B).
model ReportGeneration {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String     @map("user_id") @db.Uuid
  reportType  ReportType @map("report_type")
  filters     Json
  durationMs  Int        @map("duration_ms")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  user        User       @relation(fields: [userId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@map("report_generations")
}

enum ReportExportFormat {
  PDF
  EXCEL
  CSV
}

enum ReportExportStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

/// Milestone 11 Chunk 3B — a generated, downloadable report file. Unlike `ReportGeneration`
/// (Chunk 3A's preview-only audit trail, which never persists output), this table backs real
/// downloads: `fileData` holds the bytes directly (Postgres `bytea`) whenever Cloudinary isn't
/// configured (no real credentials in this environment — see the Reports module notes), and
/// `cloudinaryUrl`/`cloudinaryPublicId` are populated instead once it is. Generation runs
/// asynchronously (`status` PENDING -> PROCESSING -> COMPLETED/FAILED) so a large export doesn't
/// block the HTTP request — the frontend polls for completion (Part 10's "show loading progress").
model ReportExport {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String              @map("user_id") @db.Uuid
  reportType         ReportType          @map("report_type")
  format             ReportExportFormat
  filters            Json
  filtersHash        String              @map("filters_hash") @db.VarChar(64)
  status             ReportExportStatus  @default(PENDING)
  fileName           String              @map("file_name") @db.VarChar(255)
  fileSizeBytes      Int?                @map("file_size_bytes")
  cloudinaryUrl      String?             @map("cloudinary_url")
  cloudinaryPublicId String?             @map("cloudinary_public_id")
  fileData           Bytes?              @map("file_data")
  errorMessage       String?             @map("error_message")
  expiresAt          DateTime?           @map("expires_at") @db.Timestamptz(6)
  scheduleId         String?             @map("schedule_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)
  user               User                @relation(fields: [userId], references: [id])
  schedule           ReportSchedule?     @relation(fields: [scheduleId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([filtersHash, status, createdAt(sort: Desc)])
  @@map("report_exports")
}

enum ReportScheduleFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

/// Milestone 11 Chunk 3B Part 6 — a recurring report generation, executed by
/// `src/jobs/report-schedule.job.ts`. `recipientIds` are real Users (in-app notification
/// recipients via `NotificationType.REPORT_READY`) since no email-delivery infrastructure exists
/// in this codebase yet (see Known Issues) — "Recipients" is satisfied through the real
/// notification system already built in Milestone 9, not a fabricated email send.
model ReportSchedule {
  id           String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String                  @map("user_id") @db.Uuid
  reportType   ReportType              @map("report_type")
  filters      Json
  format       ReportExportFormat      @default(PDF)
  frequency    ReportScheduleFrequency
  recipientIds String[]                @map("recipient_ids")
  isEnabled    Boolean                 @default(true) @map("is_enabled")
  lastRunAt    DateTime?               @map("last_run_at") @db.Timestamptz(6)
  nextRunAt    DateTime                @map("next_run_at") @db.Timestamptz(6)
  createdAt    DateTime                @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime                @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User                    @relation(fields: [userId], references: [id])
  exports      ReportExport[]

  @@index([isEnabled, nextRunAt])
  @@index([userId, createdAt(sort: Desc)])
  @@map("report_schedules")
}

/// Milestone 11 Chunk 3B Part 7-8 — a saved report configuration a user can re-apply, favorite,
/// pin, and duplicate. Deliberately separate from Chunk 2's generic `SavedView` (Reports already
/// uses `SavedView` for quick filter shortcuts, per Part 9's filter-engine reuse) since a Template
/// carries two fields `SavedView` was never designed for (`chartsEnabled`, `columns`) and is framed
/// around reusable named presets ("Monthly Executive") rather than a personal quick filter. "Report
/// Favorites"/"Pin"/"Recently opened" (Part 8) attach to Templates rather than a separate table,
/// since a `ReportGeneration` history row has no persisted, re-openable content to favorite (see
/// Chunk 3A's own Known Issues note) and a `ReportExport` is a point-in-time file, not a reusable
/// config — a Template is the only "report" concept in this schema that a favorite/pin/duplicate
/// action meaningfully applies to.
model ReportTemplate {
  id            String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String     @map("user_id") @db.Uuid
  name          String     @db.VarChar(150)
  reportType    ReportType @map("report_type")
  filters       Json
  chartsEnabled Boolean    @default(true) @map("charts_enabled")
  columns       String[]   @default([])
  isFavorite    Boolean    @default(false) @map("is_favorite")
  isPinned      Boolean    @default(false) @map("is_pinned")
  lastUsedAt    DateTime?  @map("last_used_at") @db.Timestamptz(6)
  createdAt     DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  user          User       @relation(fields: [userId], references: [id])

  @@index([userId, isPinned])
  @@index([userId, isFavorite])
  @@map("report_templates")
}
