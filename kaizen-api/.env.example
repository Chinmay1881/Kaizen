# =============================================================================
# Muliya Kaizan — Backend Environment Variables
# Repository: kaizen-api
# Copy this file to .env and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
API_VERSION=v1

# -----------------------------------------------------------------------------
# Database (Neon PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@host.neon.tech/kaizen?sslmode=require

# -----------------------------------------------------------------------------
# Clerk Authentication
# https://dashboard.clerk.com
# -----------------------------------------------------------------------------
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# JWT verification (from Clerk dashboard → API Keys → JWT Public Key)
# Alternatively use Clerk backend SDK which handles this automatically.
CLERK_JWT_ISSUER=https://your-clerk-instance.clerk.accounts.dev

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# Production example:
# CORS_ORIGIN=https://kaizen.muliya.com

# -----------------------------------------------------------------------------
# Cloudinary
# https://cloudinary.com/console
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_FOLDER=kaizen

# -----------------------------------------------------------------------------
# File Upload Limits
# -----------------------------------------------------------------------------
MAX_FILE_SIZE_BYTES=26214400
MAX_FILES_PER_KAIZEN=10

# -----------------------------------------------------------------------------
# Rate Limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# -----------------------------------------------------------------------------
# Leaderboard
# -----------------------------------------------------------------------------
LEADERBOARD_REFRESH_INTERVAL_MS=300000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# Optional — Production
# -----------------------------------------------------------------------------
# SENTRY_DSN=
