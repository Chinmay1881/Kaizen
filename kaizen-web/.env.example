# =============================================================================
# Muliya Kaizan — Frontend Environment Variables
# Repository: kaizen-web
# Copy this file to .env.local and fill in values.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Muliya Kaizan
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Backend API
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# -----------------------------------------------------------------------------
# Clerk Authentication
# https://dashboard.clerk.com
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Clerk route configuration (custom auth pages)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_OUT_FALLBACK_REDIRECT_URL=/sign-in

# -----------------------------------------------------------------------------
# Cloudinary (client-side upload widget / unsigned upload config)
# Only the cloud name is needed on the client; signatures come from the API.
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name

# -----------------------------------------------------------------------------
# Feature Flags (MVP)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ENABLE_DARK_MODE=true

# -----------------------------------------------------------------------------
# Optional — Development
# -----------------------------------------------------------------------------
# NEXT_PUBLIC_API_MOCK=false
